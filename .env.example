# ============================================
# Verso — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.

# --- Required ---
JWT_SECRET=change-me-run-openssl-rand-hex-32

# --- Database ---
DB_DRIVER=sqlite                    # sqlite | postgres
DATABASE_URL=file:./data/db.sqlite  # or postgresql://user:pass@host:5432/verso

# --- Storage ---
STORAGE_DRIVER=local                # local | s3
STORAGE_PATH=./data

# S3 (only if STORAGE_DRIVER=s3)
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_BUCKET=verso
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# --- Authentication ---
AUTH_MODE=both                      # local | oidc | both
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# --- OIDC (only if AUTH_MODE is oidc or both) ---
# OIDC_ISSUER=https://auth.example.com/application/o/verso/
# OIDC_CLIENT_ID=verso
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=https://books.example.com/auth/callback
# OIDC_SCOPES=openid profile email
# OIDC_AUTO_REGISTER=true
# OIDC_DEFAULT_ROLE=user

# --- Server ---
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info
MAX_UPLOAD_SIZE=104857600           # 100MB
CORS_ORIGIN=*                       # Set to your domain in production

# --- PostgreSQL (only if DB_DRIVER=postgres) ---
# POSTGRES_DB=verso
# POSTGRES_USER=verso
# POSTGRES_PASSWORD=change-me
